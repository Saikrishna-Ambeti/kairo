# Optional: Kairo Connect source builds
# Leave these unset to disable optional Kairo Connect features in local source builds.
# Release builds inject their public values at build time. Do not add server-side
# secrets to this file.

# Get these from the Clerk Dashboard under API keys, JWT templates, and OAuth applications.
# KAIRO_CLERK_PUBLISHABLE_KEY=pk_test_...
# KAIRO_CLERK_JWT_TEMPLATE=kairo-relay
# KAIRO_CLERK_CLI_OAUTH_CLIENT_ID=oauthapp_...

# Get this from your relay deployment. `infra/relay` deploys update it automatically.
# KAIRO_RELAY_URL=https://relay.example.com

# Public, ingest-only mobile OpenTelemetry configuration.
# KAIRO_MOBILE_OTLP_TRACES_URL=https://api.axiom.co/v1/traces
# KAIRO_MOBILE_OTLP_TRACES_DATASET=kairo-mobile-traces-dev
# KAIRO_MOBILE_OTLP_TRACES_TOKEN=xaat-...
